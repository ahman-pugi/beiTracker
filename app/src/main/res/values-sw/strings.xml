    <!-- Help Strings -->
    <string name="help_alert_threshold_title">Kiwango cha Tahadhari</string>
    <string name="help_alert_threshold_desc">Weka asilimia ya chini ya punguzo la bei itakayokupa taarifa. Kiwango kidogo kinamaanisha utapata taarifa mara nyingi zaidi hata kwa mabadiliko madogo.</string>
    <string name="help_sync_engine_title">Injini ya Usawazishaji</string>
    <string name="help_sync_engine_desc">Inadhibiti mara ngapi BeiTracker inakagua mabadiliko ya bei. Utendaji wa Juu unakagua mara nyingi zaidi lakini unaweza kutumia betri zaidi.</string>
    <string name="help_buy_score_title">Alama ya Kununua</string>
    <string name="help_buy_score_desc">AI yetu inachambua takwimu za kihistoria, wastani wa soko, na uaminifu wa muuzaji ili kukupa alama ikiwa ni wakati mzuri wa kununua.</string>
    <string name="help_price_trend_title">Mwelekeo wa Bei</string>
    <string name="help_price_trend_desc">Inaonyesha mabadiliko ya bei kwa muda. Tumia hii kuelewa ikiwa bei ya sasa ni ya muda mfupi au ni mwelekeo wa muda mrefu.</string>
    <string name="help_verified_merchant_title">Muuzaji Aliyethibitishwa</string>
    <string name="help_verified_merchant_desc">Tunathibitisha wauzaji kulingana na historia yao, alama, na maoni ili kuhakikisha unafanya biashara na vyanzo vya kuaminika.</string>
    <string name="help_market_insights_title">Uchambuzi wa Soko</string>
    <string name="help_market_insights_desc">Taarifa za ziada kuhusu jinsi bidhaa hii inavyolingana na nyingine katika kategoria hiyo hiyo na hali ya sasa ya soko.</string>
    <string name="help_smart_tracking_title">Ufuatiliaji Mahiri</string>
    <string name="help_smart_tracking_desc">BeiTracker inatumia AI kufuatilia bei saa 24/7 katika masoko mbalimbali. Inapobaini punguzo kubwa, utapata taarifa papo hapo.</string>
    <string name="help_ai_market_intelligence_title">Uchambuzi wa Soko (AI)</string>
    <string name="help_ai_market_intelligence_desc">Injini yetu ya AI inachambua maswali yako ya lugha ya kawaida ili kupata ofa bora zaidi. Inachuja vifaa visivyo na maana na kupanga bidhaa kwa kategoria.</string>
    <string name="help_market_pulse_title">Mapigo ya Soko</string>
    <string name="help_market_pulse_desc">Muhtasari wa afya ya soko kwa ujumla. Tunachambua mabadiliko ya bei katika vituo vikuu kama Kariakoo ili kukuambia ikiwa soko ni zuri kwa mnunuzi au muuzaji.</string>
    <string name="help_market_activity_title">Shughuli za Soko</string>
    <string name="help_market_activity_desc">Inaonyesha mfululizo wa mabadiliko ya bei na tahadhari kwa bidhaa unazofuatilia. Inakusaidia kujua ni lini bei ilifikia lengo lako au ilishuka kwa kiasi kikubwa.</string>

