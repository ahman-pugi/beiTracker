    <!-- Help Strings -->
    <string name="help_alert_threshold_title">Alert Threshold</string>
    <string name="help_alert_threshold_desc">Set the minimum percentage price drop that will trigger a notification. A lower threshold means more frequent alerts for even small price changes.</string>
    <string name="help_sync_engine_title">Sync Engine</string>
    <string name="help_sync_engine_desc">Controls how often BeiTracker checks for price updates. High Performance checks more frequently but may use more battery, while Energy Saver checks less often.</string>
    <string name="help_buy_score_title">Buy Score</string>
    <string name="help_buy_score_desc">Our AI analyzes historical data, market averages, and seller reliability to give you a score on whether now is a good time to buy.</string>
    <string name="help_price_trend_title">Price Trend</string>
    <string name="help_price_trend_desc">Shows the price movement over time. Use this to understand if the current price is a temporary dip or a long-term trend.</string>
    <string name="help_verified_merchant_title">Verified Merchant</string>
    <string name="help_verified_merchant_desc">We verify sellers based on their history, ratings, and feedback to ensure you\'re dealing with reliable sources.</string>
    <string name="help_market_insights_title">Market Insights</string>
    <string name="help_market_insights_desc">Contextual information about how this product compares to others in the same category and current market conditions.</string>

    <string name="help_smart_tracking_title">Smart Tracking</string>
    <string name="help_smart_tracking_desc">BeiTracker uses AI to monitor prices 24/7 across multiple markets. When it detects a significant drop or a flash sale, you\'ll receive an instant notification.</string>

    <string name="help_ai_market_intelligence_title">AI Market Intelligence</string>
    <string name="help_ai_market_intelligence_desc">Our AI engine analyzes your natural language queries to find the best deals. It filters out irrelevant accessories, groups products by category, and identifies price trends to help you make informed decisions.</string>

    <string name="help_market_pulse_title">Market Pulse</string>
    <string name="help_market_pulse_desc">A summary of the overall market health. We analyze price volatility across major hubs like Kariakoo to tell you if it\'s a buyer\'s or seller\'s market.</string>

    <string name="help_market_activity_title">Market Activity</string>
    <string name="help_market_activity_desc">Shows a timeline of price changes and alerts for items you are tracking. It helps you keep track of when prices hit your target or dropped significantly.</string>

